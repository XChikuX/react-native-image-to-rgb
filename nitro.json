{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["aiimage"],
  "ios": {
    "iosModuleName": "NitroAiImage"
  },
  "android": {
    "androidNamespace": ["aiimage"],
    "androidCxxLibName": "NitroAiImage"
  },
  "autolinking": {
    "AiImage": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridAiImage"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridAiImage"
      }
    }
  },
  "ignorePaths": ["**/node_modules", "**/.bun"]
}
