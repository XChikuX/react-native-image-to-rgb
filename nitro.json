{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["imagetorgb"],
  "ios": {
    "iosModuleName": "NitroImageToRgb"
  },
  "android": {
    "androidNamespace": ["imagetorgb"],
    "androidCxxLibName": "NitroImageToRgb"
  },
  "autolinking": {
    "ImageToRgb": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridImageToRgb"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridImageToRgb"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules",
    "**/.bun"
  ]
}
