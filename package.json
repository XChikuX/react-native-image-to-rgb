{
  "name": "react-native-ai-image",
  "version": "0.1.2",
  "description": "AI-ready image preprocessing for React Native: zero-copy image → tensor conversion with strong YOLO/TFLite defaults.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "nitrogen",
    "android/build.gradle",
    "android/gradle.properties",
    "android/CMakeLists.txt",
    "android/src",
    "ios/**/*.swift",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "cpp",
    "nitro.json",
    "*.podspec",
    "README.md",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "npm --prefix example run",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "rm -rf android/build ios/build lib nitrogen/generated",
    "specs": "nitrogen --logLevel=debug",
    "prepare": "nitrogen --logLevel=debug && bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "nitro",
    "nitro-modules",
    "image",
    "rgb",
    "tensor",
    "preprocessing",
    "inference",
    "computer-vision",
    "tflite",
    "yolo",
    "yolov4",
    "darknet",
    "ai",
    "ml",
    "machine-learning"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XChikuX/react-native-image-to-rgb.git"
  },
  "author": "XChikuX (https://github.com/XChikuX)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/XChikuX/react-native-image-to-rgb/issues"
  },
  "homepage": "https://github.com/XChikuX/react-native-image-to-rgb#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.74.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nitrogen": "^0.35.7",
    "prettier": "^3.2.5",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-builder-bob": "^0.30.0",
    "react-native-nitro-modules": "^0.35.7",
    "release-it": "^17.0.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "packageManager": "bun@1.3.14",
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/",
      "<rootDir>/nitrogen/generated/"
    ]
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false,
          "semi": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/",
    "nitrogen/generated/",
    "example/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json",
          "tsc": "./node_modules/typescript/bin/tsc"
        }
      ]
    ]
  }
}
